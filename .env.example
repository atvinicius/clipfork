# Database
# For local dev, both point to the same local Postgres instance.
# In production (Vercel/Railway), DATABASE_URL must use the Supabase session pooler
# (aws-0-REGION.pooler.supabase.com:5432) because direct connections are IPv6-only.
# DIRECT_URL uses the direct connection (db.PROJECT_REF.supabase.co) for migrations only.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugc?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ugc?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
CLERK_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_GROWTH_PRICE_ID=""
STRIPE_SCALE_PRICE_ID=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="ugc-assets"
R2_PUBLIC_URL=""

# Firecrawl
FIRECRAWL_API_KEY=""

# OpenRouter (routes to Claude, Gemini, etc.)
OPENROUTER_API_KEY=""

# ElevenLabs
ELEVENLABS_API_KEY=""

# Apify
APIFY_API_TOKEN=""

# fal.ai (AI image/video generation)
FAL_KEY=""

# Token Encryption
TOKEN_ENCRYPTION_KEY=""

# TikTok OAuth
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
